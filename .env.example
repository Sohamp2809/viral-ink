# ── LLM provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — set LLM_PROVIDER=openai to use GPT models
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_RESEARCHER_MODEL=gpt-4o-mini
# OPENAI_WRITER_MODEL=gpt-4o
# OPENAI_CRITIC_MODEL=gpt-4o-mini

# ── Database ─────────────────────────────────────────────────────────────────
# Use sqlite:///./data/pilot.db for local single-user setup
# Use postgresql://user:password@localhost:5432/linkedin_pilot for full setup
DATABASE_URL=sqlite:///./data/pilot.db

# ── Email delivery (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Your App Name <your_verified_sender@yourdomain.com>
EMAIL_TO=your_email@example.com

# ── News / content APIs ──────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# ── Trend radar ──────────────────────────────────────────────────────────────
# Twitter/X — optional; Nitter scraping is used as fallback if absent
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit — optional; public JSON API is used as fallback if absent
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=linkedin-post-pilot/0.1

# ── LinkedIn scraping ────────────────────────────────────────────────────────
# Cookie-based auth for Playwright scraper
LINKEDIN_LI_AT_COOKIE=your_linkedin_li_at_cookie_here

# ── Pipeline schedule (cron syntax, UTC) ─────────────────────────────────────
PIPELINE_CRON=0 5 * * *
AUTOPSY_DELAY_HOURS=48
WEEKLY_DIGEST_CRON=0 18 * * 0

# ── Optional: Ollama local LLM ───────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_RESEARCHER_MODEL=llama3
# OLLAMA_WRITER_MODEL=llama3
# OLLAMA_CRITIC_MODEL=llama3